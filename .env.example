# Google OAuth Credentials
# 1. Go to Google Cloud Console
# 2. Create a project and configure OAuth consent screen (add http://localhost:3000 as authorized JavaScript origin and http://localhost:5000/api/auth/google/callback as authorized redirect URI)
# 3. Create Web Application credentials
# 4. Paste the Client ID and Client Secret here

GOOGLE_CLIENT_ID=GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=GOOGLE_CLIENT_SECRET

# JWT Secret for sessions
JWT_SECRET=replace_with_a_secure_random_string_in_production
